# Environment variables for Render (Web Service)
# Copy each key/value into Render → Environment

# Required — paste your FULL MongoDB Atlas URI (same value for both)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?appName=Cluster0
DATABASE_URL=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?appName=Cluster0

# Required — long random secret (Render can auto-generate)
NEXTAUTH_SECRET=replace-with-long-random-secret

# Required — your live Render URL (update after first deploy)
NEXTAUTH_URL=https://YOUR-SERVICE-NAME.onrender.com

# Optional
GEMINI_API_KEY=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASSWORD=
ADMIN_EMAIL=syntaxsoftwaresolution@gmail.com

# Do NOT set PORT — Render sets it automatically
# NODE_ENV=production is fine to set on Render
